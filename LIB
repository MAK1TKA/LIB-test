            Btn.MouseEnter:Connect(function()
                tween(Btn, {BackgroundColor3 = Color3.fromRGB(42, 42, 42)}, 0.15)
            end)
            Btn.MouseLeave:Connect(function()
                tween(Btn, {BackgroundColor3 = Color3.fromRGB(32, 32, 32)}, 0.15)
            end)
            Btn.MouseButton1Click:Connect(function()
                tween(Btn, {BackgroundColor3 = Color3.fromRGB(55, 55, 55)}, 0.1)
                task.wait(0.1)
                tween(Btn, {BackgroundColor3 = Color3.fromRGB(32, 32, 32)}, 0.2)
