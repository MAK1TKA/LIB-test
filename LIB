            end)

            RunService.RenderStepped:Connect(function()
                if dragging then
                    local mouseX = UserInputService:GetMouseLocation().X
                    local trackX = Track.AbsolutePosition.X
                    local trackW = Track.AbsoluteSize.X
                    local pct = math.clamp((mouseX - trackX) / trackW, 0, 1)
                    local newVal = config.Min + (config.Max - config.Min) * pct
                    local step = config.Step or 1
                    newVal = math.round(newVal / step) * step
                    newVal = math.clamp(newVal, config.Min, config.Max)
                    if newVal ~= value then
                        value = newVal
                        ValueLabel.Text = tostring(value)
                        Fill.Size = UDim2.new(pct, 0, 1, 0)
                        Knob.Position = UDim2.new(pct, 0, 0.5, 0)
                        pcall(config.Callback, value)
                    end
                end
            end)

            local SliderObj = {}
            function SliderObj:Set(val)
                val = math.clamp(val, config.Min, config.Max)
                value = val
                local pct = (val - config.Min) / (config.Max - config.Min)
                ValueLabel.Text = tostring(val)
                tween(Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.2)
                tween(Knob, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.2)
                pcall(config.Callback, val)
            end
            return SliderObj
        end

        -- Инпут
        function Tab:CreateInput(config)
            elementOrder += 1

            local Container = Instance.new("Frame")
            Container.Size = UDim2.new(1, 0, 0, 38)
            Container.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
            Container.BorderSizePixel = 0
            Container.LayoutOrder = elementOrder
            Container.Parent = TabPage
            corner(Container, 6)
            stroke(Container, Color3.fromRGB(45, 45, 45))

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(0.4, 0, 1, 0)
            Label.Position = UDim2.new(0, 12, 0, 0)
            Label.BackgroundTransparency = 1
            Label.Text = config.Name
            Label.TextColor3 = Color3.fromRGB(230, 230, 230)
            Label.Font = Enum.Font.Gotham
            Label.TextSize = 13
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = Container

            local InputBox = Instance.new("TextBox")
            InputBox.Size = UDim2.new(0.55, -10, 0, 26)
            InputBox.Position = UDim2.new(0.45, 0, 0.5, -13)
            InputBox.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            InputBox.Text = config.Default or ""
            InputBox.PlaceholderText = config.Placeholder or "..."
            InputBox.PlaceholderColor3 = Color3.fromRGB(80, 80, 80)
            InputBox.TextColor3 = Color3.fromRGB(220, 220, 220)
            InputBox.Font = Enum.Font.Gotham
            InputBox.TextSize = 12
            InputBox.BorderSizePixel = 0
            InputBox.ClearTextOnFocus = false
            InputBox.Parent = Container
            corner(InputBox, 4)
            stroke(InputBox, Color3.fromRGB(55, 55, 55))

            local pad = Instance.new("UIPadding")
            pad.PaddingLeft = UDim.new(0, 8)
            pad.Parent = InputBox

            InputBox.FocusLost:Connect(function(entered)
                if entered or not config.OnlyOnEnter then
                    pcall(config.Callback, InputBox.Text)
                end
            end)

            InputBox.Focused:Connect(function()
                tween(InputBox, {BackgroundColor3 = Color3.fromRGB(28, 28, 28)}, 0.15)
            end)
            InputBox.FocusLost:Connect(function()
                tween(InputBox, {BackgroundColor3 = Color3.fromRGB(22, 22, 22)}, 0.15)
            end)
        end

        -- Лейбл
        function Tab:CreateLabel(text)
            elementOrder += 1
            local Lbl = Instance.new("TextLabel")
            Lbl.Size = UDim2.new(1, 0, 0, 30)
            Lbl.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
            Lbl.Text = "  " .. text
            Lbl.TextColor3 = Color3.fromRGB(180, 180, 180)
            Lbl.Font = Enum.Font.Gotham
            Lbl.TextSize = 12
            Lbl.TextXAlignment = Enum.TextXAlignment.Left
            Lbl.BorderSizePixel = 0
            Lbl.LayoutOrder = elementOrder
            Lbl.Parent = TabPage
            corner(Lbl, 6)

            local LabelObj = {}
            function LabelObj:Set(newText)
                Lbl.Text = "  " .. newText
            end
            return LabelObj
        end

        return Tab
    end

    -- Уведомление
    function Window:Notify(config)
        local NotifHolder = ScreenGui:FindFirstChild("Notifications") or Instance.new("Frame")
        NotifHolder.Name = "Notifications"
        NotifHolder.Size = UDim2.new(0, 280, 1, 0)
        NotifHolder.Position = UDim2.new(1, -290, 0, 0)
        NotifHolder.BackgroundTransparency = 1
        NotifHolder.Parent = ScreenGui

        local NLayout = NotifHolder:FindFirstChildOfClass("UIListLayout") or Instance.new("UIListLayout")
        NLayout.SortOrder = Enum.SortOrder.LayoutOrder
        NLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
        NLayout.Padding = UDim.new(0, 6)
        NLayout.Parent = NotifHolder

        local NPad = NotifHolder:FindFirstChildOfClass("UIPadding") or Instance.new("UIPadding")
        NPad.PaddingBottom = UDim.new(0, 10)
        NPad.PaddingRight = UDim.new(0, 0)
        NPad.Parent = NotifHolder

        local Notif = Instance.new("Frame")
        Notif.Size = UDim2.new(1, 0, 0, 0)
        Notif.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
        Notif.BorderSizePixel = 0
        Notif.ClipsDescendants = true
        Notif.Parent = NotifHolder
        corner(Notif, 8)
        stroke(Notif, Color3.fromRGB(50, 50, 50))

        local NTitle = Instance.new("TextLabel")
        NTitle.Size = UDim2.new(1, -16, 0, 24)
        NTitle.Position = UDim2.new(0, 12, 0, 8)
        NTitle.BackgroundTransparency = 1
        NTitle.Text = config.Title or "Уведомление"
        NTitle.TextColor3 = Color3.fromRGB(240, 240, 240)
        NTitle.Font = Enum.Font.GothamBold
        NTitle.TextSize = 13
        NTitle.TextXAlignment = Enum.TextXAlignment.Left
        NTitle.Parent = Notif

        local NContent = Instance.new("TextLabel")
        NContent.Size = UDim2.new(1, -16, 0, 32)
        NContent.Position = UDim2.new(0, 12, 0, 30)
        NContent.BackgroundTransparency = 1
        NContent.Text = config.Content or ""
        NContent.TextColor3 = Color3.fromRGB(160, 160, 160)
        NContent.Font = Enum.Font.Gotham
        NContent.TextSize = 12
        NContent.TextXAlignment = Enum.TextXAlignment.Left
        NContent.TextWrapped = true
        NContent.Parent = Notif

        tween(Notif, {Size = UDim2.new(1, 0, 0, 72)}, 0.3)
        task.delay(config.Duration or 4, function()
            tween(Notif, {Size = UDim2.new(1, 0, 0, 0)}, 0.3)
            task.wait(0.35)
            Notif:Destroy()
        end)
    end

    -- Анимация появления
    Main.Size = UDim2.new(0, 550, 0, 0)
    Main.BackgroundTransparency = 1
    tween(Main, {Size = UDim2.new(0, 550, 0, 380), BackgroundTransparency = 0}, 0.4)

    return Window
end

return MyLib
