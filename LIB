            Lbl.Text = "  " .. text
            Lbl.TextColor3 = Color3.fromRGB(180, 180, 180)
            Lbl.Font = Enum.Font.Gotham
            Lbl.TextSize = 12
            Lbl.TextXAlignment = Enum.TextXAlignment.Left
            Lbl.BorderSizePixel = 0
            Lbl.LayoutOrder = elementOrder
            Lbl.Parent = TabPage
