    StatusLabel.BackgroundTransparency = 1
    StatusLabel.Text = ""
    StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    StatusLabel.Font = Enum.Font.Gotham
    StatusLabel.TextSize = 13
    StatusLabel.ZIndex = 1002
    StatusLabel.Parent = MainFrame

    -- Плавное появление
    MainFrame.BackgroundTransparency = 1
    Title.TextTransparency = 1
    Subtitle.TextTransparency = 1
    InputField.BackgroundTransparency = 1
    SubmitBtn.BackgroundTransparency = 1
    InputField.TextTransparency = 1

    tween(BgOverlay, {BackgroundTransparency = 0.6}, 0.4)
    tween(MainFrame, {BackgroundTransparency = 0}, 0.5)
    tween(Title, {TextTransparency = 0}, 0.5)
    tween(Subtitle, {TextTransparency = 0}, 0.5)
    tween(InputField, {BackgroundTransparency = 0}, 0.5)
    tween(SubmitBtn, {BackgroundTransparency = 0}, 0.5)
    tween(InputField, {TextTransparency = 0}, 0.5)

    local function submit()
        if callback(InputField.Text) then
            -- ✅ Правильный ключ - плавное исчезновение
            StatusLabel.Text = "✓ Accepted"
            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)

            task.wait(0.3)

            tween(BgOverlay, {BackgroundTransparency = 1}, 0.4)
            tween(MainFrame, {BackgroundTransparency = 1}, 0.4)
            tween(Title, {TextTransparency = 1}, 0.4)
            tween(Subtitle, {TextTransparency = 1}, 0.4)
            tween(InputField, {BackgroundTransparency = 1}, 0.4)
            tween(SubmitBtn, {BackgroundTransparency = 1}, 0.4)

            task.wait(0.5)
            KeyPromptGui:Destroy()
        else
            -- ❌ Неправильный ключ - красный эффект
            StatusLabel.Text = "✗ Invalid Key"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)

            tween(InputField, {BackgroundColor3 = Color3.fromRGB(80, 30, 40)}, 0.15)
            task.wait(0.5)
            tween(InputField, {BackgroundColor3 = Color3.fromRGB(20, 25, 50)}, 0.3)

            InputField.Text = ""
            task.wait(0.5)
            StatusLabel.Text = ""
        end
    end

    SubmitBtn.MouseButton1Click:Connect(submit)

    SubmitBtn.MouseEnter:Connect(function()
        tween(SubmitBtn, {BackgroundColor3 = Color3.fromRGB(100, 160, 255)}, 0.15)
        BtnStroke.Transparency = 0
    end)

    SubmitBtn.MouseLeave:Connect(function()
        tween(SubmitBtn, {BackgroundColor3 = Color3.fromRGB(80, 140, 255)}, 0.15)
        BtnStroke.Transparency = 0.3
    end)

    InputField.FocusLost:Connect(function(entered)
        if entered then
            submit()
        end
    end)
end

