        function Tab:CreateToggle(config)
            elementOrder += 1
            local state = config.Default or false

            local Container = Instance.new("Frame")
            Container.Size = UDim2.new(1, 0, 0, 38)
            Container.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
            Container.BorderSizePixel = 0
            Container.LayoutOrder = elementOrder
            Container.Parent = TabPage
            corner(Container, 6)
            stroke(Container, Color3.fromRGB(45, 45, 45))

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(1, -60, 1, 0)
            Label.Position = UDim2.new(0, 12, 0, 0)
            Label.BackgroundTransparency = 1
            Label.Text = config.Name
            Label.TextColor3 = Color3.fromRGB(230, 230, 230)
            Label.Font = Enum.Font.Gotham
            Label.TextSize = 13
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = Container

            local Switch = Instance.new("Frame")
            Switch.Size = UDim2.new(0, 44, 0, 24)
            Switch.Position = UDim2.new(1, -54, 0.5, -12)
            Switch.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            Switch.BorderSizePixel = 0
            Switch.Parent = Container
            corner(Switch, 12)

            local Knob = Instance.new("Frame")
            Knob.Size = UDim2.new(0, 18, 0, 18)
            Knob.Position = UDim2.new(0, 3, 0.5, -9)
            Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Knob.BorderSizePixel = 0
            Knob.Parent = Switch
            corner(Knob, 9)

            local Interact = Instance.new("TextButton")
            Interact.Size = UDim2.new(1, 0, 1, 0)
            Interact.BackgroundTransparency = 1
            Interact.Text = ""
            Interact.Parent = Container

            local function updateVisual()
                if state then
                    tween(Switch, {BackgroundColor3 = Color3.fromRGB(50, 150, 255)}, 0.2)
                    tween(Knob, {Position = UDim2.new(1, -21, 0.5, -9)}, 0.2)
                else
                    tween(Switch, {BackgroundColor3 = Color3.fromRGB(60, 60, 60)}, 0.2)
                    tween(Knob, {Position = UDim2.new(0, 3, 0.5, -9)}, 0.2)
                end
            end

            updateVisual()

            Interact.MouseButton1Click:Connect(function()
                state = not state
                updateVisual()
                pcall(config.Callback, state)
            end)

            Container.MouseEnter:Connect(function()
                tween(Container, {BackgroundColor3 = Color3.fromRGB(38, 38, 38)}, 0.15)
            end)
            Container.MouseLeave:Connect(function()
                tween(Container, {BackgroundColor3 = Color3.fromRGB(32, 32, 32)}, 0.15)
            end)

            local ToggleObj = {}
            function ToggleObj:Set(value)
                state = value
                updateVisual()
                pcall(config.Callback, state)
            end
            return ToggleObj
        end

        function Tab:CreateDropdown(config)
            elementOrder += 1
            local selected = config.Default or config.Options[1]
            local isOpen = false
            local maxVisibleItems = 6

            local Container = Instance.new("Frame")
            Container.Size = UDim2.new(1, 0, 0, 38)
            Container.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
            Container.BorderSizePixel = 0
            Container.LayoutOrder = elementOrder
            Container.ZIndex = 5
            Container.Parent = TabPage
            corner(Container, 6)
            stroke(Container, Color3.fromRGB(45, 45, 45))

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(0.5, 0, 1, 0)
            Label.Position = UDim2.new(0, 12, 0, 0)
            Label.BackgroundTransparency = 1
            Label.Text = config.Name
            Label.TextColor3 = Color3.fromRGB(230, 230, 230)
            Label.Font = Enum.Font.Gotham
            Label.TextSize = 13
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.ZIndex = 6
            Label.Parent = Container

            local SelectedLabel = Instance.new("TextLabel")
            SelectedLabel.Size = UDim2.new(0.45, -20, 1, 0)
            SelectedLabel.Position = UDim2.new(0.5, 0, 0, 0)
            SelectedLabel.BackgroundTransparency = 1
            SelectedLabel.Text = selected
            SelectedLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
            SelectedLabel.Font = Enum.Font.Gotham
            SelectedLabel.TextSize = 12
            SelectedLabel.TextXAlignment = Enum.TextXAlignment.Right
            SelectedLabel.ZIndex = 6
            SelectedLabel.Parent = Container

            local Arrow = Instance.new("TextLabel")
            Arrow.Size = UDim2.new(0, 20, 1, 0)
            Arrow.Position = UDim2.new(1, -24, 0, 0)
            Arrow.BackgroundTransparency = 1
            Arrow.Text = "▼"
            Arrow.TextColor3 = Color3.fromRGB(120, 120, 120)
            Arrow.Font = Enum.Font.Gotham
            Arrow.TextSize = 11
            Arrow.ZIndex = 6
            Arrow.Parent = Container

            local DropList = Instance.new("Frame")
            DropList.Size = UDim2.new(0, 0, 0, 0)
            DropList.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
            DropList.BorderSizePixel = 0
            DropList.ClipsDescendants = true
            DropList.ZIndex = 100
            DropList.Visible = false
            DropList.Parent = ScreenGui
            corner(DropList, 6)
            stroke(DropList, Color3.fromRGB(50, 50, 50))

            local ScrollFrame = Instance.new("ScrollingFrame")
            ScrollFrame.Size = UDim2.new(1, 0, 1, 0)
            ScrollFrame.BackgroundTransparency = 1
            ScrollFrame.ScrollBarThickness = 2
            ScrollFrame.ScrollBarImageColor3 = Color3.fromRGB(70, 70, 70)
            ScrollFrame.BorderSizePixel = 0
            ScrollFrame.Parent = DropList

            local DropLayout = Instance.new("UIListLayout")
            DropLayout.SortOrder = Enum.SortOrder.LayoutOrder
            DropLayout.Padding = UDim.new(0, 2)
            DropLayout.Parent = ScrollFrame

            local DropPad = Instance.new("UIPadding")
            DropPad.PaddingTop = UDim.new(0, 4)
            DropPad.PaddingBottom = UDim.new(0, 4)
            DropPad.PaddingLeft = UDim.new(0, 4)
            DropPad.PaddingRight = UDim.new(0, 4)
            DropPad.Parent = ScrollFrame

            local optionHeight = 30
            local visibleItems = math.min(#config.Options, maxVisibleItems)
            local totalHeight = (visibleItems * (optionHeight + 2)) + 8

            local function closeDropdown()
                isOpen = false
                Arrow.Text = "▼"
                tween(DropList, {Size = UDim2.new(0, DropList.AbsoluteSize.X, 0, 0)}, 0.15)
                task.wait(0.17)
                DropList.Visible = false
            end

            local function openDropdown()
                local absPos = Container.AbsolutePosition
                local absSize = Container.AbsoluteSize
                local dropW = absSize.X
                local dropX = absPos.X
                local dropY = absPos.Y + absSize.Y + 4

                DropList.Position = UDim2.new(0, dropX, 0, dropY)
                DropList.Size = UDim2.new(0, dropW, 0, 0)
                DropList.Visible = true
                ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, DropLayout.AbsoluteContentSize.Y + 8)
                tween(DropList, {Size = UDim2.new(0, dropW, 0, totalHeight)}, 0.15)
            end

            for i, option in ipairs(config.Options) do
                local OptBtn = Instance.new("TextButton")
                OptBtn.Size = UDim2.new(1, 0, 0, optionHeight)
                OptBtn.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
                OptBtn.BackgroundTransparency = option == selected and 0 or 1
                OptBtn.Text = option
                OptBtn.TextColor3 = option == selected and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 180)
                OptBtn.Font = Enum.Font.Gotham
                OptBtn.TextSize = 12
                OptBtn.BorderSizePixel = 0
                OptBtn.LayoutOrder = i
                OptBtn.ZIndex = 101
                OptBtn.Parent = ScrollFrame
                corner(OptBtn, 4)

                OptBtn.MouseEnter:Connect(function()
                    if option ~= selected then
                        tween(OptBtn, {BackgroundTransparency = 0.5}, 0.1)
                    end
                end)
                OptBtn.MouseLeave:Connect(function()
                    if option ~= selected then
                        tween(OptBtn, {BackgroundTransparency = 1}, 0.1)
                    end
                end)

                OptBtn.MouseButton1Click:Connect(function()
                    selected = option
                    SelectedLabel.Text = option

                    for _, child in ipairs(ScrollFrame:GetChildren()) do
                        if child:IsA("TextButton") then
                            local isSel = child.Text == selected
                            tween(child, {
                                BackgroundTransparency = isSel and 0 or 1,
                                TextColor3 = isSel and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 180)
                            }, 0.15)
                        end
                    end

                    closeDropdown()
                    pcall(config.Callback, selected)
                end)
            end

            local Interact = Instance.new("TextButton")
            Interact.Size = UDim2.new(1, 0, 1, 0)
            Interact.BackgroundTransparency = 1
            Interact.Text = ""
            Interact.ZIndex = 7
            Interact.Parent = Container

            Interact.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    Arrow.Text = "▲"
                    openDropdown()
                else
                    closeDropdown()
                end
            end)

            UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 and isOpen then
                    local mousePos = UserInputService:GetMouseLocation()
                    local dp = DropList.AbsolutePosition
                    local ds = DropList.AbsoluteSize
                    local cp = Container.AbsolutePosition
                    local cs = Container.AbsoluteSize

                    local inDrop = mousePos.X >= dp.X and mousePos.X <= dp.X + ds.X
                        and mousePos.Y >= dp.Y and mousePos.Y <= dp.Y + ds.Y
                    local inContainer = mousePos.X >= cp.X and mousePos.X <= cp.X + cs.X
                        and mousePos.Y >= cp.Y and mousePos.Y <= cp.Y + cs.Y

                    if not inDrop and not inContainer then
                        closeDropdown()
                    end
                end
            end)

            local DropObj = {}
            function DropObj:Set(value)
                selected = value
                SelectedLabel.Text = value
                pcall(config.Callback, selected)
            end
            return DropObj
        end

        function Tab:CreateSlider(config)
            elementOrder += 1
            local value = config.Default or config.Min

            local Container = Instance.new("Frame")
            Container.Size = UDim2.new(1, 0, 0, 52)
            Container.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
            Container.BorderSizePixel = 0
            Container.LayoutOrder = elementOrder
            Container.Parent = TabPage
            corner(Container, 6)
            stroke(Container, Color3.fromRGB(45, 45, 45))

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(1, -60, 0, 24)
            Label.Position = UDim2.new(0, 12, 0, 4)
            Label.BackgroundTransparency = 1
            Label.Text = config.Name
            Label.TextColor3 = Color3.fromRGB(230, 230, 230)
            Label.Font = Enum.Font.Gotham
            Label.TextSize = 13
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = Container

            local ValueLabel = Instance.new("TextLabel")
            ValueLabel.Size = UDim2.new(0, 50, 0, 24)
            ValueLabel.Position = UDim2.new(1, -58, 0, 4)
            ValueLabel.BackgroundTransparency = 1
            ValueLabel.Text = tostring(value)
            ValueLabel.TextColor3 = Color3.fromRGB(100, 180, 255)
            ValueLabel.Font = Enum.Font.GothamBold
            ValueLabel.TextSize = 13
            ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
            ValueLabel.Parent = Container

            local Track = Instance.new("Frame")
            Track.Size = UDim2.new(1, -24, 0, 6)
            Track.Position = UDim2.new(0, 12, 0, 36)
            Track.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            Track.BorderSizePixel = 0
            Track.Parent = Container
            corner(Track, 3)

            local Fill = Instance.new("Frame")
            Fill.Size = UDim2.new((value - config.Min) / (config.Max - config.Min), 0, 1, 0)
            Fill.BackgroundColor3 = Color3.fromRGB(50, 150, 255)
            Fill.BorderSizePixel = 0
            Fill.Parent = Track
            corner(Fill, 3)

            local Knob = Instance.new("Frame")
            Knob.Size = UDim2.new(0, 14, 0, 14)
            Knob.AnchorPoint = Vector2.new(0.5, 0.5)
            Knob.Position = UDim2.new((value - config.Min) / (config.Max - config.Min), 0, 0.5, 0)
            Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Knob.BorderSizePixel = 0
            Knob.ZIndex = 2
            Knob.Parent = Track
            corner(Knob, 7)

            local Interact = Instance.new("TextButton")
            Interact.Size = UDim2.new(1, 0, 3, 0)
            Interact.Position = UDim2.new(0, 0, 0.5, 0)
            Interact.AnchorPoint = Vector2.new(0, 0.5)
            Interact.BackgroundTransparency = 1
            Interact.Text = ""
            Interact.ZIndex = 3
            Interact.Parent = Track

            local dragging = false
            Interact.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)

            RunService.RenderStepped:Connect(function()
                if dragging then
                    local mouseX = UserInputService:GetMouseLocation().X
                    local trackX = Track.AbsolutePosition.X
                    local trackW = Track.AbsoluteSize.X
                    local pct = math.clamp((mouseX - trackX) / trackW, 0, 1)
                    local newVal = config.Min + (config.Max - config.Min) * pct
                    local step = config.Step or 1
                    newVal = math.round(newVal / step) * step
                    newVal = math.clamp(newVal, config.Min, config.Max)
                    if newVal ~= value then
                        value = newVal
                        ValueLabel.Text = tostring(value)
                        Fill.Size = UDim2.new(pct, 0, 1, 0)
                        Knob.Position = UDim2.new(pct, 0, 0.5, 0)
                        pcall(config.Callback, value)
                    end
                end
            end)

            local SliderObj = {}
            function SliderObj:Set(val)
                val = math.clamp(val, config.Min, config.Max)
                value = val
                local pct = (val - config.Min) / (config.Max - config.Min)
                ValueLabel.Text = tostring(val)
                tween(Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.2)
                tween(Knob, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.2)
                pcall(config.Callback, val)
            end
            return SliderObj
        end

        function Tab:CreateInput(config)
            elementOrder += 1

            local Container = Instance.new("Frame")
            Container.Size = UDim2.new(1, 0, 0, 38)
            Container.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
            Container.BorderSizePixel = 0
            Container.LayoutOrder = elementOrder
            Container.Parent = TabPage
            corner(Container, 6)
            stroke(Container, Color3.fromRGB(45, 45, 45))

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(0.4, 0, 1, 0)
            Label.Position = UDim2.new(0, 12, 0, 0)
            Label.BackgroundTransparency = 1
            Label.Text = config.Name
            Label.TextColor3 = Color3.fromRGB(230, 230, 230)
            Label.Font = Enum.Font.Gotham
            Label.TextSize = 13
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = Container

            local InputBox = Instance.new("TextBox")
            InputBox.Size = UDim2.new(0.55, -10, 0, 26)
            InputBox.Position = UDim2.new(0.45, 0, 0.5, -13)
            InputBox.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
            InputBox.Text = config.Default or ""
            InputBox.PlaceholderText = config.Placeholder or "..."
            InputBox.PlaceholderColor3 = Color3.fromRGB(80, 80, 80)
